{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kachuful-server",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-27",
  "durable_objects": {
    "bindings": [
      {
        "name": "GAME_HUB",
        "class_name": "GameHub"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "GameHub"
      ]
    }
  ]
}
